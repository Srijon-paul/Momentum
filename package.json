{
    "name": "momentum",
    "version": "1.0.0",
    "description": "Production-ready REST API for an opportunity discovery platform built with Express.js, Prisma, PostgreSQL and JWT authentication.",
    "keywords": [
        "momentum",
        "opportunity-platform",
        "express",
        "postgresql",
        "backend",
        "prisma",
        "node.js"
    ],
    "license": "MIT",
    "author": "Srijon Paul",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "start": "node index.js",
        "dev": "nodemon index.js",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate deploy",
        "prisma:studio": "prisma studio",
        "seed": "prisma db seed",
        "build": "npm install && prisma generate && prisma migrate deploy",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check"
    },
    "engines": {
        "node": ">=22"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "express-slow-down": "^3.1.0",
        "helmet": "^8.2.0",
        "hpp": "^0.2.3",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.11.0",
        "pg": "^8.21.0",
        "swagger-jsdoc": "^6.3.0",
        "swagger-ui-express": "^5.0.1",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.9.3",
        "@types/pg": "^8.20.0",
        "eslint": "^10.7.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.7.0",
        "nodemon": "^3.1.14",
        "prettier": "^3.9.6",
        "prisma": "^7.8.0",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3"
    }
}
